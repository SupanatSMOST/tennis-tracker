# Copy to .env and fill in REAL values. .env is gitignored — never commit it.

# --- Postgres (compose-internal; its port is not exposed to the host) ---
POSTGRES_USER=tennis
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=tennis

# --- Connection string used by both the app and goose migrations ---
# Host is the compose service name "db". Keep user/password/db in sync with the above.
DATABASE_URL=postgres://tennis:CHANGE_ME_strong_db_password@db:5432/tennis?sslmode=disable

# --- JWT signing key — generate a long random value: openssl rand -base64 48 ---
# Rotating this invalidates every issued (non-expiring) token.
JWT_SIGNING_KEY=CHANGE_ME_long_random_secret

# --- Host port to expose the API on (container always listens on 8080) ---
APP_PORT=8080
